---
import Logo from "../assets/minimal.svg";
import ContactModal from "./ContactModal.astro";
---

<footer class="footer">
	<div class="footer-bar">
		<nav class="footer-nav" aria-label="Footer">
			<div class="footer-nav-row">
				<a href="/">INICIO</a>
				<a href="/shows">SHOWS</a>
				<a href="/videos" target="_blank">VIDEOS</a>
				<a href="/about">NOSOTROS</a>
			</div>
		</nav>
		<div class="footer-logo">
			<Logo class="logo" />
		</div>
		<div class="footer-contact">
			<button class="contact-button" type="button" data-contact-open>
				¿Quieres contactarnos?
			</button>
		</div>
	</div>
	<div class="footer-bottom">
		<p>&copy; 2026 Todos los derechos reservados.</p>
	</div>
</footer>
<ContactModal />

<style>
	.footer {
		background-color: #000;
		color: #ffffff;
		padding: 18px 24px 16px;
		margin-top: 0;
		border-top: 1px solid #333;
		font-family: Impact, sans-serif;
	}

	.footer-bar {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
		grid-template-areas: "nav logo contact";
		align-items: center;
		gap: 24px;
		max-width: 1200px;
		margin: 0 auto 16px;
	}

	.footer-contact {
		grid-area: contact;
		display: flex;
		align-items: center;
		justify-content: flex-end;
	}

	.contact-button {
		border: 1px solid rgba(255, 255, 255, 0.35);
		background: transparent;
		color: #ffffff;
		padding: 10px 16px;
		border-radius: 999px;
		font-size: 0.9rem;
		letter-spacing: 0.02rem;
		cursor: pointer;
		transition: border-color 0.3s ease, color 0.3s ease, transform 0.2s ease;
		font-family: Impact, "Haettenschweiler", "Arial Narrow Bold", sans-serif !important;
	}

	.contact-button:hover,
	.contact-button:focus-visible {
		border-color: #5d0cff;
		color: #5d0cff;
		transform: translateY(-1px);
	}

	.contact-button:focus-visible {
		outline: none;
		box-shadow: 0 0 0 2px rgba(93, 12, 255, 0.4);
	}

	.footer-logo {
		grid-area: logo;
		display: flex;
		justify-content: center;
	}

	.footer-logo :global(.logo) {
		width: 58px;
		height: 58px;
	}

	.footer-nav {
		grid-area: nav;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 8px;
	}

	.footer-nav-row {
		display: flex;
		flex-wrap: wrap;
		gap: 16px;
		justify-content: flex-start;
	}

	.footer-nav-row a,
	.footer-nav-row a:visited {
		color: #ffffff !important;
		font-family: Impact, "Haettenschweiler", "Arial Narrow Bold", sans-serif;
		text-decoration: none;
		transition: all 0.5s ease;
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 0.6px;
		position: relative;
		display: inline-block;
	}

	.footer-nav-row a::after {
		content: '';
		position: absolute;
		bottom: -5px;
		left: 0;
		right: 0;
		height: 2px;
		background-color: #5d0cff;
		transform: scaleX(0);
		transition: transform 0.5s ease;
	}

	.footer-nav-row a:hover {
		color: #5d0cff !important;
	}

	.footer-nav-row a:hover::after {
		transform: scaleX(1);
	}

	.footer-bottom {
		border-top: 1px solid #333;
		padding-top: 12px;
		text-align: center;
		font-size: 0.85rem;
		font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
		color: rgba(255, 255, 255, 0.75);
	}

	.footer-bottom p {
		margin: 0;
	}

	@media (max-width: 768px) {
		.footer {
			padding: 20px 16px;
			margin-top: 0;
		}

		.footer-bar {
			grid-template-columns: 1fr;
			grid-template-areas:
				"logo"
				"nav"
				"contact";
			gap: 16px;
		}

		.footer-contact {
			justify-content: center;
		}

		.footer-logo :global(.logo) {
			width: 62px;
			height: 62px;
		}

		.footer-nav {
			align-items: center;
		}

		.footer-nav-row {
			justify-content: center;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.contact-button {
			transition: none;
		}
	}

	@media (max-width: 768px) {
		.contact-button {
			width: 100%;
			max-width: 280px;
		}
	}
</style>
