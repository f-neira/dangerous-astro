				</a>
			</li>
			<li>
				<a href="https://www.youtube.com/@Dangerous_Band" target="_blank" aria-label="YouTube">
					<svg viewBox="0 0 24 24" fill="currentColor">
						<path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 11.75a29 29 0 00.46 5.33A2.78 2.78 0 003.4 19.54c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 001.94-2 29 29 0 00.46-5.25 29 29 0 00-.46-5.33zM9.75 15.02V8.98l5.92 3.03z"/>
					</svg>
				</a>
			</li>
		</ul>
	</div>
</div>

<style>
	.social-float {
		position: fixed;
		right: clamp(32px, 8vw, 180px);
		bottom: clamp(28px, 7vh, 140px);
		z-index: 900;
		background: rgba(20, 20, 20, 0.7);
		border: 1px solid rgba(255, 255, 255, 0.2);
		border-radius: 16px;
		backdrop-filter: blur(6px);
		box-shadow: 0 12px 26px rgba(0, 0, 0, 0.25);
		color: #ffffff;
		font-family: Impact, sans-serif;
		min-width: 240px;
		transition: opacity 0.3s ease, transform 0.3s ease;
	}

	.social-float.is-hidden {
		opacity: 0;
		transform: translateY(12px);
		pointer-events: none;
	}

	.social-float-content {
		padding: 18px 22px 16px;
		text-align: center;
	}

	.social-float-title {
		margin: 0 0 10px 0;
		font-size: 0.95rem;
		letter-spacing: 1px;
		text-transform: uppercase;
		color: #ffffff;
	}

	.social-float-icons {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		justify-content: center;
		gap: 18px;
	}

	.social-float-icons li {
		margin: 0;
	}

	.social-float-icons a {
		color: #ffffff;
		text-decoration: none;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 44px;
		height: 44px;
		border-radius: 50%;
		border: 1px solid rgba(255, 255, 255, 0.3);
		background: rgba(0, 0, 0, 0.2);
		transition: transform 0.2s ease, border-color 0.2s ease, color 0.2s ease;
	}

	.social-float-icons svg {
		width: 22px;
		height: 22px;
		display: block;
	}

	.social-float-icons a:hover {
		transform: translateY(-2px);
		border-color: #ffffff;
		color: #ffffff;
	}

	@media (max-width: 768px) {
		.social-float {
			right: 16px;
			bottom: 16px;
			min-width: 200px;
		}

		.social-float-content {
			padding: 14px;
		}

		.social-float-title {
			font-size: 0.8rem;
		}
	}
</style>

<script>
	let onScroll: (() => void) | undefined;

	const setupSocialFloat = () => {
		cleanupSocialFloat();
		const socialFloat = document.querySelector('.social-float');
		const footer = document.querySelector('footer.footer');

		if (!socialFloat || !footer) {
			return;
		}

		let ticking = false;

		const updateVisibility = () => {
			const floatRect = socialFloat.getBoundingClientRect();
			const footerRect = footer.getBoundingClientRect();
			const isOverlapping =
				floatRect.right > footerRect.left &&
				floatRect.left < footerRect.right &&
				floatRect.bottom > footerRect.top &&
				floatRect.top < footerRect.bottom;

			socialFloat.classList.toggle('is-hidden', isOverlapping);
			ticking = false;
		};

		onScroll = () => {
			if (!ticking) {
				window.requestAnimationFrame(updateVisibility);
				ticking = true;
			}
		};

		updateVisibility();
		window.addEventListener('scroll', onScroll, { passive: true });
		window.addEventListener('resize', onScroll);
	};

	const cleanupSocialFloat = () => {
		if (onScroll) {
			window.removeEventListener('scroll', onScroll);
			window.removeEventListener('resize', onScroll);
			onScroll = undefined;
		}
	};

	document.addEventListener('DOMContentLoaded', setupSocialFloat);
	document.addEventListener('astro:page-load', setupSocialFloat);
	document.addEventListener('astro:before-swap', cleanupSocialFloat);
</script>
