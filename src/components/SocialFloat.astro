					</svg>
				</a>
			</li>
			<li>
				<a href="https://www.tiktok.com/@dangerous.band" target="_blank" aria-label="TikTok">
					<svg viewBox="0 0 24 24" fill="currentColor">
						<path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.4v13.38a2.6 2.6 0 1 1-2.6-2.6c.29 0 .57.05.83.13V9.44a6 6 0 0 0-.83-.06 6.04 6.04 0 0 0-6.04 6.04 6.04 6.04 0 0 0 6.04 6.04 6.04 0 0 0 6.04 -6.04V9.24a8.2 8.2 0 0 0 4.73 1.5V7.5c-.36.05-.73.08-1.1.08z"/>
