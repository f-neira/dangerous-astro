---
import MinimalLogo from "../assets/minimal.svg";

const { label = "Cargando" } = Astro.props;
---

<div id="loading-overlay" class="loading-overlay" aria-live="polite" aria-busy="true">
	<div class="loading-overlay__content">
		<MinimalLogo class="loading-overlay__logo" aria-label="Dangerous" />
		<span class="loading-overlay__text">
			{label}<span class="loading-overlay__dots" aria-hidden="true">...</span>
		</span>
	</div>
</div>

<script>
	const overlayId = "loading-overlay";

	const getOverlay = () => document.getElementById(overlayId);

	const hideOverlay = () => {
		const overlay = getOverlay();
		if (!overlay || overlay.classList.contains("loading-overlay--hidden")) {
			return;
		}

		overlay.classList.add("loading-overlay--hidden");
		overlay.addEventListener(
			"transitionend",
			() => {
				overlay.remove();
			},
			{ once: true }
		);
	};

	const hideOnReady = () => {
		if (!getOverlay()) {
			return;
		}

		if (document.readyState === "complete") {
			hideOverlay();
		} else {
			window.addEventListener("load", hideOverlay, { once: true });
		}
	};

	if (!window.__dangerousLoadingOverlayBound) {
		window.__dangerousLoadingOverlayBound = true;
		document.addEventListener("astro:page-load", hideOnReady);
		document.addEventListener("astro:after-swap", hideOnReady);
	}

	hideOnReady();
</script>

<style>
	.loading-overlay {
		position: fixed;
		inset: 0;
		z-index: 9999;
		display: flex;
		align-items: center;
		justify-content: center;
		background-color: #000;
		color: #f5f5f5;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		transition: opacity 0.35s ease, visibility 0.35s ease;
	}

	.loading-overlay__content {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.75rem;
		font-family: "Impact", "Haettenschweiler", "Arial Narrow Bold", sans-serif;
	}

	.loading-overlay__logo {
		width: 120px;
		height: auto;
		color: #f5f5f5;
	}

	.loading-overlay__text {
		font-size: 0.95rem;
		letter-spacing: 0.2em;
	}

	.loading-overlay__dots {
		display: inline-block;
		overflow: hidden;
		width: 1.5em;
		vertical-align: bottom;
		animation: dots 1.2s steps(4, end) infinite;
	}

	.loading-overlay--hidden {
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
	}

	@keyframes dots {
		0% {
			width: 0;
		}
		100% {
			width: 1.5em;
		}
	}
</style>
