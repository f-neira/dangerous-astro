---
import Logo from "../assets/logo.svg";
---

<nav class="navbar">
	<div class="nav-left">
		<ul class="nav-links">
			<li><a href="/">INICIO</a></li>
			<li><a href="/shows">SHOWS</a></li>
		</ul>
	</div>
	<div class="nav-center">
		<a href="/" class="logo-link" aria-label="Ir al inicio">
			<Logo class="logo"/>
		</a>
	</div>
	<div class="nav-right">
		<ul class="nav-links">
			<li><a href="https://www.youtube.com/@Dangerous_Band" target="_blank">VIDEOS</a></li>
			<li><a href="/about">NOSOTROS</a></li>
		</ul>
	</div>
	<button
		class="hamburger"
		id="hamburger"
		aria-label="Abrir menu"
		aria-controls="mobileMenu"
		aria-expanded="false"
	>
		<span></span>
		<span></span>
		<span></span>
	</button>
</nav>

<div class="mobile-overlay" id="mobileOverlay"></div>

<nav class="mobile-menu" id="mobileMenu" aria-label="Navegacion movil">
	<ul class="mobile-nav-links">
		<li><a href="/" aria-label="Ir a inicio">Inicio</a></li>
		<li><a href="/shows" aria-label="Ir a shows">Shows</a></li>
		<li><a href="/videos" aria-label="Ir a videos">Videos</a></li>
		<li><a href="/about" aria-label="Ir a nosotros">Nosotros</a></li>
	</ul>
</nav>

<script>
	let cleanupNav: (() => void) | undefined;

	const setupNav = () => {
		cleanupNav?.();

		const hamburger = document.getElementById('hamburger');
		const mobileMenu = document.getElementById('mobileMenu');
		const mobileOverlay = document.getElementById('mobileOverlay');

		if (!hamburger || !mobileMenu || !mobileOverlay) {
			return;
		}

		const setExpandedState = (isOpen: boolean) => {
			hamburger.setAttribute('aria-expanded', String(isOpen));
			hamburger.setAttribute('aria-label', isOpen ? 'Cerrar menu' : 'Abrir menu');
		};

		const closeMenu = () => {
			hamburger.classList.remove('active');
			mobileMenu.classList.remove('active');
			mobileOverlay.classList.remove('active');
			setExpandedState(false);
		};

		const toggleMenu = () => {
			const isOpen = hamburger.classList.toggle('active');
			mobileMenu.classList.toggle('active', isOpen);
			mobileOverlay.classList.toggle('active', isOpen);
			setExpandedState(isOpen);
		};

		const mobileLinks = mobileMenu.querySelectorAll('a');

		setExpandedState(false);

		hamburger.addEventListener('click', toggleMenu);
		mobileOverlay.addEventListener('click', closeMenu);
		mobileLinks.forEach((link) => link.addEventListener('click', closeMenu));

		cleanupNav = () => {
			hamburger.removeEventListener('click', toggleMenu);
			mobileOverlay.removeEventListener('click', closeMenu);
			mobileLinks.forEach((link) => link.removeEventListener('click', closeMenu));
		};
	};

	document.addEventListener('astro:page-load', setupNav);
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', setupNav, { once: true });
	} else {
		setupNav();
	}
	document.addEventListener('astro:before-swap', () => cleanupNav?.());
</script>

<style>
	.navbar {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		background-color: #000;
		color: white;
		padding: 0 2rem;
		min-height: var(--nav-height);
		z-index: 100;
		box-shadow:
			0 10px 26px rgba(0, 0, 0, 0.45),
			inset 0 1px 0 rgba(255, 255, 255, 0.08);
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 1rem;
		isolation: isolate;
	}

	.navbar::after {
		content: '';
		position: absolute;
		left: 0;
		right: 0;
		pointer-events: none;
	}

	.navbar::after {
		bottom: -18px;
		height: 18px;
		background: linear-gradient(
			180deg,
			rgba(0, 0, 0, 0.55),
			rgba(0, 0, 0, 0)
		);
	}

	.nav-left,
	.nav-right {
		display: flex;
		align-items: center;
	}

	.nav-center {
		display: flex;
		justify-content: center;
		align-items: center;
		margin: 0 1.5rem;
	}

	.logo {
        width: 250px;
		height: auto;
		color: white;
		filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.2));
	}

	.logo-link {
		display: flex;
		align-items: center;
		justify-content: center;
		text-decoration: none;
		transition: transform 0.3s ease;
	}

	.logo-link:hover {
		transform: scale(1.05);
	}

	.nav-links {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		gap: 1.5rem;
	}

	.nav-links a {
		color: white;
		text-decoration: none;
		transition: all 0.5s ease;
		font-weight: 500;
		font-size: 0.95rem;
		font-family: Impact, sans-serif;
		position: relative;
		display: inline-block;
	}

	.nav-links a::after {
		content: '';
		position: absolute;
		bottom: -5px;
		left: 0;
		right: 0;
		height: 2px;
		background-color: #5d0cff;
		transform: scaleX(0);
		transition: transform 0.5s ease;
	}

	.nav-links a:hover {
		color: #5d0cff;
	}

	.nav-links a:hover::after {
		transform: scaleX(1);
	}

	.hamburger {
		display: none;
		flex-direction: column;
		background: none;
		border: none;
		cursor: pointer;
		gap: 0.4rem;
		padding: 0;
		margin-left: auto;
	}

	.hamburger span {
		width: 25px;
		height: 3px;
		background-color: white;
		border-radius: 2px;
		transition: all 0.3s ease;
	}

	.hamburger.active span:nth-child(1) {
		transform: rotate(45deg) translate(10px, 10px);
	}

	.hamburger.active span:nth-child(2) {
		opacity: 0;
	}

	.hamburger.active span:nth-child(3) {
		transform: rotate(-45deg) translate(7px, -7px);
	}

	.mobile-menu {
		position: fixed;
		top: var(--nav-height);
		left: 0;
		right: 0;
		background-color: #000;
		padding: 1.5rem 2rem 2rem;
		box-shadow: 0 4px 6px rgba(0, 0, 0, 0.2);
		z-index: 99;
		max-height: calc(100vh - var(--nav-height));
		overflow-y: auto;
		opacity: 0;
		transform: translateY(-10px);
		visibility: hidden;
		pointer-events: none;
		transition: opacity 0.25s ease, transform 0.25s ease, visibility 0s linear 0.25s;
	}

	.mobile-menu.active {
		opacity: 1;
		transform: translateY(0);
		visibility: visible;
		pointer-events: auto;
		transition: opacity 0.25s ease, transform 0.25s ease;
	}

	.mobile-overlay {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background-color: rgba(0, 0, 0, 0.7);
		backdrop-filter: blur(6px);
		-webkit-backdrop-filter: blur(6px);
		z-index: 98;
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
		transition: opacity 0.25s ease, visibility 0s linear 0.25s;
	}

	.mobile-overlay.active {
		opacity: 1;
		visibility: visible;
		pointer-events: auto;
		transition: opacity 0.25s ease;
	}

	.mobile-nav-links {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		text-align: center;
	}

	.mobile-nav-links a {
		color: white;
		text-decoration: none;
		transition: all 0.5s ease;
		font-weight: 500;
		display: inline-block;
		padding: 0.5rem 0;
		font-family: Impact, sans-serif;
		position: relative;
	}

	.mobile-nav-links a::after {
		content: '';
		position: absolute;
		bottom: -6px;
		left: 0;
		right: 0;
		height: 2px;
		background-color: #5d0cff;
		transform: scaleX(0);
		transform-origin: center;
		transition: transform 0.5s ease;
	}

	.mobile-nav-links a:hover {
		color: #5d0cff;
	}

	.mobile-nav-links a:hover::after {
		transform: scaleX(1);
	}

	@media (max-width: 768px) {
		.navbar {
			padding: 0 1rem;
			gap: 0.5rem;
		}

		.nav-left,
		.nav-right {
			display: none;
		}

		.nav-center {
			position: absolute;
			left: 50%;
			transform: translateX(-50%);
			margin: 0;
		}

		.logo {
			width: 170px;
			height: auto;
		}

		.hamburger {
			display: flex;
		}

		.hamburger span {
			width: 30px;
			height: 3px;
		}

		.mobile-nav-links {
			gap: 1.25rem;
		}

		.mobile-nav-links a {
			font-size: 1.2rem;
			padding: 0.65rem 0;
			letter-spacing: 0.04rem;
		}
	}
</style>
